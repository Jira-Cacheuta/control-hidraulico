# Copiar a .env y rellenar con tus valores. No subir .env a GitHub.
PORT=4000
JIRA_BASE_URL=https://tu-empresa.atlassian.net
JIRA_EMAIL=tu-email@ejemplo.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=CH
# Lista separada por comas. Si está definida, GET /api/issues usa solo estas keys (estados, summary y base para transiciones del diagrama).
# Incluir aquí todas las CH del mapa; ejemplo — Losa radiante parque: CH-1188,CH-1189,CH-1190,CH-1191,CH-1192,CH-1193
JIRA_ISSUE_KEYS=
